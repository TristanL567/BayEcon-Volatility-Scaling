library(knitr)
Path <- this.path::this.dir()
setwd(Path)
Directory_LaTeX <- file.path(Path, "BayEcon_ResultsPresentation_Part2_h11815352.Rnw")
knit2pdf(Directory_LaTeX, output = file.path(Path, "BayEcon_ResultsPresentation_Part2_h11815352.tex"))
